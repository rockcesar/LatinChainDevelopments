<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <template id="pdfreader" name="PDF Reader">
            <t t-call="web.layout">
                &lt;!DOCTYPE html&gt;
                <html lang="en">
                    <head>
                        <meta charset="UTF-8"/>
                        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                        <title>PDF Reader</title>
                        
                        <script src="https://cdn.tailwindcss.com"></script>
                        <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
                        
                        <style>
                            body { font-family: 'Inter', sans-serif; }
                            
                            /* Ocultar las flechas de los inputs numéricos */
                            input[type="number"]::-webkit-inner-spin-button,
                            input[type="number"]::-webkit-outer-spin-button {
                                -webkit-appearance: none;
                                margin: 0;
                            }
                            input[type="number"] {
                                -moz-appearance: textfield;
                            }

                            /* Estilo general del scrollbar */
                            ::-webkit-scrollbar { width: 8px; height: 8px; }
                            ::-webkit-scrollbar-track { background: #f1f1f1; }
                            ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
                            ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

                            .grab-cursor { cursor: grab; }
                            .grabbing-cursor { cursor: grabbing; }
                        </style>
                        
                        <script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
                        
                        <script src="https://sdk.minepi.com/pi-sdk.js"></script>
                        
                        <script type="text/javascript">
                            startCommonAppsAI();
                        </script>
                        
                        <div id="blockingOverlay" style="display: flex; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.7); z-index: 9999; justify-content: center; align-items: center;">
                            <div style="display: flex; background-color: white; padding: 30px; border-radius: 10px; text-align: center; font-family: Arial, sans-serif; font-size: 24px; color: #333;">
                                <div id="blocking-message" style="display: none;">
                                    <div>
                                        Go to Pi Browser
                                    </div>
                                    <div>
                                        <a class="anchor-click" style="color: blue;" href="#" target="_blank">Click here</a>
                                    </div>
                                </div>
                                <div id="paying-message" style="display: none;">
                                    <div>
                                        Donate to unlock Apps
                                    </div>
                                    <div>
                                        <a class="anchor-click" style="color: blue;" href="#">Click here</a>
                                    </div>
                                    <div t-if="mainnet in ['Mainnet ON', 'Mainnet OFF']">
                                        <br/>
                                        <a id="test_app" style="color: blue;" href="#">Or here to test this app</a>
                                    </div>
                                </div>
                                <div id="loading-message" style="display: block;">
                                    Loading...
                                </div>
                            </div>
                        </div>
                        <input type="hidden" id="sandbox" t-att-value="sandbox"/>
                        <input type="hidden" id="mainnet" t-att-value="mainnet"/>
                        <div id="pi_prowser_message" style="display:none;">You need to access from Pi Browser.</div>
                    </head>
                    <body class="bg-gray-100 h-screen flex flex-col overflow-hidden" translate="no">

                        <header class="bg-white shadow-sm border-b border-gray-200 z-10">
                            <div class="max-w-7xl mx-auto px-4 py-3 flex flex-col sm:flex-row items-center justify-between gap-4">
                                
                                <!-- Logo / Carga de archivo pequeña -->
                                <div class="flex items-center gap-3 w-full sm:w-auto justify-between">
                                    <div class="flex items-center gap-2 text-blue-600 font-bold text-lg">
                                        <i class="fa-solid fa-file-pdf w-6 h-6" fill="currentColor" viewBox="0 0 24 24"></i>
                                        <!--<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9.5 8.5V13H8v-1.5h1.5v-3H8V7h3v4.5zm5 1.5h-2.5V7H15v6z"/></svg>-->
                                        <span>PDF Reader</span>
                                        
                                        <a id="back" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-1/2 px-3 rounded back" style="margin-bottom:15px;" href="/"><i class="fa fa-step-backward"></i></a>
                                        
                                        <!-- Add this Dropdown Menu inside your Header / Toolbar, right next to the file upload or zoom controls -->
                                        <div class="relative inline-block text-left">
                                          <button id="menuButton" class="p-2 bg-gray-100 rounded-lg hover:bg-gray-200 text-gray-700 transition" aria-haspopup="true" aria-expanded="false">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
                                            </svg>
                                          </button>

                                          <!-- Dropdown panel, hidden by default -->
                                          <div id="dropdownMenu" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg z-50 ring-1 ring-black ring-opacity-5">
                                            <div class="py-1" role="menu" aria-orientation="vertical" aria-labelledby="menuButton">
                                              <button id="btnSearch" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">
                                                🔍 Search Words
                                              </button>
                                              <button id="btnPrint" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">
                                                🖨️ Print PDF
                                              </button>
                                              <button id="btnDownload" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">
                                                ⬇️ Download PDF
                                              </button>
                                            </div>
                                          </div>
                                        </div>
                                    </div>
                                    <label class="sm:hidden cursor-pointer bg-blue-50 text-blue-600 px-3 py-1 rounded-md text-sm font-medium border border-blue-200 hover:bg-blue-100 transition-colors">
                                        <input type="file" id="file-upload-mobile" class="hidden" accept="application/pdf"/>
                                        Open PDF
                                    </label>
                                </div>

                                <div class="flex flex-wrap items-center justify-center gap-2 sm:gap-4 w-full sm:w-auto">
                                    
                                    <!-- Zoom Controls -->
                                    <div class="flex items-center bg-gray-50 rounded-lg border border-gray-200 p-1">
                                        <button id="zoom-out" class="p-1.5 rounded hover:bg-white hover:shadow-sm text-gray-600 disabled:opacity-50 transition-all" title="Zoom Out" disabled="disabled">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/></svg>
                                        </button>
                                        <span id="zoom-level" class="text-sm font-medium px-2 text-gray-700 min-w-[3rem] text-center">100%</span>
                                        <button id="zoom-in" class="p-1.5 rounded hover:bg-white hover:shadow-sm text-gray-600 disabled:opacity-50 transition-all" title="Zoom In" disabled="disabled">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                                        </button>
                                    </div>

                                    <!-- Page Controls -->
                                    <div class="flex items-center bg-gray-50 rounded-lg border border-gray-200 p-1">
                                        <button id="prev-page" class="p-1.5 rounded hover:bg-white hover:shadow-sm text-gray-600 disabled:opacity-50 transition-all" title="Previous Page" disabled="disabled">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                                        </button>
                                        
                                        <div class="flex items-center px-2 text-sm text-gray-700 gap-1">
                                            <input type="number" id="page-num-input" class="w-10 text-center bg-white border border-gray-300 rounded px-1 py-0.5 font-medium focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" value="0" disabled="disabled"/>
                                            <span class="text-gray-500">/ <span id="page-count">0</span></span>
                                        </div>

                                        <button id="next-page" class="p-1.5 rounded hover:bg-white hover:shadow-sm text-gray-600 disabled:opacity-50 transition-all" title="Next Page" disabled="disabled">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                        </button>
                                    </div>

                                    <label class="hidden sm:inline-block cursor-pointer bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium shadow-sm hover:bg-blue-700 transition-colors">
                                        <input type="file" id="file-upload-desktop" class="hidden" accept="application/pdf"/>
                                        Upload Document
                                    </label>
                                </div>
                            </div>
                        </header>

                        <main class="flex-grow flex relative overflow-hidden bg-gray-200">
                            
                            <!-- Estado Vacío (Scrollable on small screens) -->
                            <div id="empty-state" class="absolute inset-0 flex overflow-y-auto z-10 bg-gray-100">
                                <div class="m-auto flex flex-col items-center justify-center p-6 sm:p-8 text-center max-w-md w-full bg-white rounded-2xl shadow-sm border border-gray-200">
                                    <div class="w-20 h-20 bg-blue-50 text-blue-500 rounded-full flex items-center justify-center mb-6">
                                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                    </div>
                                    <h2 class="text-xl font-bold text-gray-800 mb-2">No document open</h2>
                                    <p class="text-gray-500 mb-6 text-sm">Upload a PDF file from your device to start viewing and navigating its pages.</p>
                                    <label class="cursor-pointer bg-blue-600 text-white px-6 py-3 rounded-xl font-medium shadow-sm hover:bg-blue-700 hover:shadow transition-all w-full sm:w-auto">
                                        <input type="file" id="file-upload-main" class="hidden" accept="application/pdf"/>
                                        Select PDF File
                                    </label>
                                </div>
                            </div>

                            <!-- Contenedor del PDF (Habilita Scroll real) -->
                            <div id="canvas-wrapper" tabindex="0" class="w-full h-full overflow-auto -webkit-overflow-scrolling-touch flex justify-center hidden outline-none pt-4 pb-4">
                                <canvas id="pdf-canvas" class="max-w-none shadow-xl bg-white grab-cursor"></canvas>
                            </div>

                            <!-- Loading Spinner -->
                            <div id="loading-spinner" class="absolute inset-0 bg-white/80 backdrop-blur-sm flex items-center justify-center z-20 hidden">
                                <div class="animate-spin rounded-full h-12 w-12 border-4 border-blue-200 border-t-blue-600"></div>
                            </div>
                        </main>
                        
                        <script type="text/javascript" src="/website_pinetwork_games_odoo/static/src/js/apps/pdfreader_functions.js?v=1.107"></script>
                    </body>
                </html>
            </t>
		</template>

</odoo>
