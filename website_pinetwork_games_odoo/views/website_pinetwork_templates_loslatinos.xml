<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <template id="loslatinos" name="Los Latinos">
            <t t-call="web.layout">
            &lt;!DOCTYPE html&gt;
            <html>
                <head>
                    <meta charset="UTF-8"/>
                    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
                    <title>Los Latinos</title>
                    <script src="https://cdn.tailwindcss.com"></script>
                    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
                    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
                    <style>
                        body { margin: 0; overflow: hidden; background-color: #87CEEB; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; touch-action: none; }
                        #game-canvas { position: absolute; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1; }
                        .ui-layer { position: absolute; z-index: 10; pointer-events: none; }
                        .interactive { pointer-events: auto; }
                        
                        /* Custom Scrollbar for menus */
                        ::-webkit-scrollbar { width: 6px; }
                        ::-webkit-scrollbar-track { background: rgba(0,0,0,0.1); }
                        ::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.3); border-radius: 3px; }
                        
                        #notification-area { top: 20px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; gap: 8px; align-items: center; }
                        .notification { background: rgba(0, 0, 0, 0.8); color: white; padding: 8px 16px; border-radius: 20px; font-size: 14px; animation: fadeOut 4s forwards; }
                        @keyframes fadeOut { 0% { opacity: 1; transform: translateY(0); } 80% { opacity: 1; transform: translateY(0); } 100% { opacity: 0; transform: translateY(-20px); } }

                        /* Color Picker Styling */
                        input[type="color"] { -webkit-appearance: none; border: none; padding: 0; }
                        input[type="color"]::-webkit-color-swatch-wrapper { padding: 0; }
                        input[type="color"]::-webkit-color-swatch { border: 1px solid #4B5563; border-radius: 0.375rem; }
                    </style>
                    
                    <script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
                
                    <script src="https://sdk.minepi.com/pi-sdk.js"></script>
                    
                    <script type="text/javascript">
                        startCommonAppsAI();
                    </script>
                    
                    <div id="blockingOverlay" style="display: flex; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.7); z-index: 9999; justify-content: center; align-items: center;">
                        <div style="display: flex; background-color: white; padding: 30px; border-radius: 10px; text-align: center; font-family: Arial, sans-serif; font-size: 24px; color: #333;">
                            <div id="blocking-message" style="display: none;">
                                <div>
                                    Go to Pi Browser
                                </div>
                                <div>
                                    <a class="anchor-click" style="color: blue;" href="#" target="_blank">Click here</a>
                                </div>
                            </div>
                            <div id="paying-message" style="display: none;">
                                <div>
                                    Pay Pi to GET PREMIUM
                                </div>
                                <div>
                                    <a class="anchor-click" style="color: blue;" href="#">Click here</a>
                                </div>
                                <div t-if="mainnet in ['Mainnet ON', 'Mainnet OFF']">
                                    <br/>
                                    <a id="test_app" style="color: blue;" href="#">Or here to test this app</a>
                                </div>
                            </div>
                            <div id="loading-message" style="display: block;">
                                Loading...
                            </div>
                        </div>
                    </div>
                    <input type="hidden" id="sandbox" t-att-value="sandbox"/>
                    <input type="hidden" id="mainnet" t-att-value="mainnet"/>
                    <div id="pi_prowser_message" style="display:none;">You need to access from Pi Browser.</div>
                </head>
                <body>

                    <!-- Canvas -->
                    <canvas id="game-canvas"></canvas>

                    <!-- Start Screen -->
                    <div id="start-screen" class="ui-layer interactive w-full h-full bg-gray-900 text-white z-50 absolute top-0 left-0 overflow-y-auto">
                        <!-- Inner wrapper to handle safe scrolling and padding -->
                        <div class="min-h-full flex flex-col items-center py-12 px-4">
                            
                            <!-- my-auto safely centers content vertically, but only if there is extra room -->
                            <div class="my-auto w-full flex flex-col items-center">
                                
                                <h1 class="text-5xl font-bold mb-2 text-green-400 text-center">Los Latinos</h1>
                                <p class="mb-8 text-gray-400 text-center" id="t-subtitle">The Ultimate Life Simulator</p>
                                
                                <div class="bg-gray-800 p-6 rounded-lg shadow-lg w-full max-w-sm">
                                    <label class="block text-sm mb-1" id="t-lang">Language / Idioma</label>
                                    <select id="lang-select" class="w-full mb-4 p-2 rounded bg-gray-700 text-white border border-gray-600 focus:outline-none" onchange="updateStartScreenLang()">
                                        <option value="en">English</option>
                                        <option value="es">Español Latino</option>
                                    </select>

                                    <label class="block text-sm mb-1" id="t-city">Select City</label>
                                    <select id="city-select" class="w-full mb-4 p-2 rounded bg-gray-700 text-white border border-gray-600 focus:outline-none">
                                        <option value="caracas">Caracas, Venezuela</option>
                                        <option value="mexico">Ciudad de México</option>
                                        <option value="buenosaires">Buenos Aires, Argentina</option>
                                        <option value="miami">Miami, USA</option>
                                        <option value="tegucigalpa">Tegucigalpa, Honduras</option>
                                    </select>

                                    <label class="block text-sm mb-1" id="t-sex">Your Sex</label>
                                    <select id="sex-select" class="w-full mb-4 p-2 rounded bg-gray-700 text-white border border-gray-600 focus:outline-none">
                                        <option value="male" id="t-male">Male</option>
                                        <option value="female" id="t-female">Female</option>
                                    </select>

                                    <!-- Character Customization -->
                                    <div class="border-t border-gray-700 pt-4 mb-6">
                                        <p class="text-sm font-bold mb-3 text-center text-gray-300" id="t-appearance">Appearance / Apariencia</p>
                                        <div class="grid grid-cols-2 gap-4">
                                            <div>
                                                <label class="block text-xs mb-1 text-gray-400" id="t-skin">Skin Color</label>
                                                <input type="color" id="color-skin" value="#d09b68" class="w-full h-8 cursor-pointer rounded bg-gray-700"/>
                                            </div>
                                            <div>
                                                <label class="block text-xs mb-1 text-gray-400" id="t-hair">Hair Color</label>
                                                <input type="color" id="color-hair" value="#111111" class="w-full h-8 cursor-pointer rounded bg-gray-700"/>
                                            </div>
                                            <div>
                                                <label class="block text-xs mb-1 text-gray-400" id="t-shirt">Shirt Color</label>
                                                <input type="color" id="color-shirt" value="#3b82f6" class="w-full h-8 cursor-pointer rounded bg-gray-700"/>
                                            </div>
                                            <div>
                                                <label class="block text-xs mb-1 text-gray-400" id="t-pants">Pants Color</label>
                                                <input type="color" id="color-pants" value="#1f2937" class="w-full h-8 cursor-pointer rounded bg-gray-700"/>
                                            </div>
                                        </div>
                                    </div>

                                    <button onclick="startGame()" class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-4 rounded transition shadow-lg" id="t-startbtn">
                                        Start Life / Empezar
                                    </button>
                                    <button onclick="clearSave()" class="w-full mt-3 bg-red-500/20 border border-red-500 hover:bg-red-500 hover:text-white text-red-400 font-bold py-2 px-4 rounded text-sm transition" id="t-clearbtn">
                                        Delete Save / Borrar Partida
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- HUD -->
                    <div id="hud" class="ui-layer w-full h-full hidden">
                        
                        <!-- Top Stats Bar -->
                        <div class="absolute top-4 left-4 bg-white/90 p-3 rounded-lg shadow-lg backdrop-blur-sm min-w-[150px] interactive">
                            <div class="font-bold text-lg text-green-700 mb-1">$<span id="ui-money">0</span></div>
                            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1" id="t-energy">Energy</div>
                            <div class="w-full bg-gray-300 rounded-full h-2 mb-2"><div id="bar-energy" class="bg-yellow-400 h-2 rounded-full transition-all" style="width: 100%"></div></div>
                            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1" id="t-hunger">Hunger</div>
                            <div class="w-full bg-gray-300 rounded-full h-2 mb-2"><div id="bar-hunger" class="bg-orange-500 h-2 rounded-full transition-all" style="width: 100%"></div></div>
                            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1" id="t-fun">Fun</div>
                            <div class="w-full bg-gray-300 rounded-full h-2"><div id="bar-fun" class="bg-blue-400 h-2 rounded-full transition-all" style="width: 100%"></div></div>
                        </div>

                        <!-- Zoom Controls -->
                        <div class="absolute top-4 right-4 flex flex-col gap-2 interactive">
                            <button onclick="zoomCamera('in')" class="bg-gray-800/70 text-white w-10 h-10 rounded shadow-lg flex items-center justify-center hover:bg-gray-700 font-bold text-2xl transition">
                                +
                            </button>
                            <button onclick="zoomCamera('out')" class="bg-gray-800/70 text-white w-10 h-10 rounded shadow-lg flex items-center justify-center hover:bg-gray-700 font-bold text-2xl transition">
                                -
                            </button>
                        </div>

                        <!-- Notification Area -->
                        <div id="notification-area" class="ui-layer"></div>

                        <!-- Virtual Joystick (Auto-shows on Mobile) -->
                        <div id="joystick-zone" class="absolute bottom-8 left-8 w-32 h-32 bg-gray-500/30 rounded-full border-2 border-white/50 interactive hidden backdrop-blur-sm z-40 touch-none">
                            <div id="joystick-knob" class="absolute top-1/2 left-1/2 w-12 h-12 bg-white rounded-full transform -translate-x-1/2 -translate-y-1/2 shadow-lg pointer-events-none transition-transform duration-75"></div>
                        </div>

                        <!-- Bottom Actions (Phone & Shop) -->
                        <div class="absolute bottom-6 right-6 flex flex-col gap-3 interactive">
                            <button onclick="toggleMenu('shop-menu')" class="bg-purple-600 text-white p-4 rounded-full shadow-lg hover:bg-purple-700 transform hover:scale-105 transition">
                                🛒
                            </button>
                            <button onclick="toggleMenu('phone-menu')" class="bg-blue-600 text-white p-4 rounded-full shadow-lg hover:bg-blue-700 transform hover:scale-105 transition">
                                📱
                            </button>
                        </div>
                    </div>

                    <!-- Phone Menu -->
                    <div id="phone-menu" class="ui-layer interactive hidden absolute bottom-40 sm:bottom-24 left-4 right-4 sm:left-auto sm:right-24 sm:w-64 bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-200">
                        <div class="bg-blue-600 text-white p-3 font-bold text-center" id="t-phone">Phone</div>
                        <div class="p-4 flex flex-col gap-2 max-h-64 overflow-y-auto">
                            <button onclick="goToWork()" class="bg-gray-100 p-3 rounded-lg text-left hover:bg-gray-200 font-semibold text-gray-800 transition" id="t-work">💼 Go to Work (+ $50)</button>
                            <button onclick="orderFood()" class="bg-gray-100 p-3 rounded-lg text-left hover:bg-gray-200 font-semibold text-gray-800 transition" id="t-order">🍕 Order Food (- $15)</button>
                            <button onclick="sleep()" class="bg-gray-100 p-3 rounded-lg text-left hover:bg-gray-200 font-semibold text-gray-800 transition" id="t-sleep">🛏️ Sleep</button>
                            
                            <!-- Fun Actions -->
                            <button onclick="playGames()" class="bg-yellow-100 p-3 rounded-lg text-left hover:bg-yellow-200 font-semibold text-yellow-800 transition" id="t-play">🎮 Play Games</button>
                            <button onclick="dance()" class="bg-red-100 p-3 rounded-lg text-left hover:bg-red-200 font-semibold text-red-800 transition" id="t-dance">🕺 Dance</button>
                            <button onclick="watchTV()" class="bg-indigo-100 p-3 rounded-lg text-left hover:bg-indigo-200 font-semibold text-indigo-800 transition" id="t-watchtv">📺 Watch TV</button>

                            <button onclick="inviteNeighbor()" class="bg-green-100 p-3 rounded-lg text-left hover:bg-green-200 font-semibold text-green-800 transition" id="t-invite">👋 Invite New Neighbor</button>
                        </div>
                    </div>

                    <!-- Shop Menu -->
                    <div id="shop-menu" class="ui-layer interactive hidden absolute bottom-40 sm:bottom-24 left-4 right-4 sm:left-auto sm:right-24 sm:w-72 bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-200">
                        <div class="bg-purple-600 text-white p-3 font-bold text-center" id="t-shop">Furniture Shop</div>
                        <div class="p-4 flex flex-col gap-2 max-h-64 overflow-y-auto" id="shop-items">
                            <!-- Populated via JS -->
                        </div>
                    </div>

                    <!-- NPC Interaction Menu -->
                    <div id="interaction-menu" class="ui-layer interactive hidden absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-64 bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-200">
                        <div class="bg-pink-500 text-white p-3 font-bold text-center" id="npc-name">Neighbor</div>
                        <div class="p-4 flex flex-col gap-2">
                            <div class="text-sm text-gray-600 mb-2 font-semibold" id="t-rel">Relationship: <span id="ui-rel" class="text-pink-500">0</span>%</div>
                            <button onclick="interactNPC('chat')" class="bg-gray-100 p-3 rounded-lg text-left hover:bg-gray-200 font-semibold text-gray-800 transition" id="t-chat">💬 Chat</button>
                            <button onclick="interactNPC('joke')" class="bg-gray-100 p-3 rounded-lg text-left hover:bg-gray-200 font-semibold text-gray-800 transition" id="t-joke">😂 Tell a Joke</button>
                            <button onclick="interactNPC('romance')" class="bg-pink-100 p-3 rounded-lg text-left hover:bg-pink-200 font-semibold text-pink-800 transition hidden" id="btn-romance">❤️ Flirt</button>
                            <button onclick="closeInteraction()" class="mt-2 text-gray-400 hover:text-gray-600 text-sm font-bold text-center w-full" id="t-close">Close</button>
                        </div>
                    </div>

                    <script type="text/javascript" src="/website_pinetwork_games_odoo/static/src/js/games/loslatinos_functions.js?v=1.102"></script>
                </body>
            </html>
            </t>
		</template>

</odoo>
